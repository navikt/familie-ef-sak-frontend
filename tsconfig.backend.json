{
    "compilerOptions": {
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "lib": ["ES2022"],
        "outDir": "dist/server",
        "rootDir": "src/backend",
        "declaration": true,
        "sourceMap": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["src/backend"],
    "exclude": ["node_modules"],
    "tsc-alias": {
        "resolveFullPaths": true,
        "verbose": false
    }
}
