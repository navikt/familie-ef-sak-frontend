{
    "name": "familie-ef-sak-frontend",
    "version": "0.0.1",
    "main": "dist/server/server.js",
    "repository": "https://github.com/navikt/familie-ef-sak-frontend.git",
    "author": "Nav - teamfamilie",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "start": "NODE_ENV=production node dist/server/server.js",
        "dev": "tsc -p tsconfig.backend.json && npm run tsc-alias && NODE_ENV=development node dist/server/server-lokal.js",
        "build": "npm run lint && npm run build:prod && npm run tsc-alias",
        "build:prod": "tsc -p tsconfig.backend.json && vite build",
        "lint": "tsc --noEmit && eslint './src/**/*.{js,ts,tsx}'",
        "lint:fix": "eslint './src/**/*.{js,ts,tsx}' --fix",
        "test": "vitest run --exclude '**/dist/**'",
        "tsc-alias": "tsc-alias -p tsconfig.backend.json"
    },
    "lint-staged": {
        "src/**/*.{js,jsx,ts,tsx,json}": ["prettier --write", "eslint --fix"]
    },
    "dependencies": {
        "@navikt/aksel-icons": "^7.39.0",
        "@navikt/ds-css": "7.39.0",
        "@navikt/ds-react": "7.39.0",
        "@navikt/ds-tokens": "7.39.0",
        "@navikt/fnrvalidator": "^2.1.5",
        "@navikt/oasis": "^4.1.4",
        "@sentry/browser": "^10.47.0",
        "@sentry/core": "^10.26.0",
        "axios": "^1.14.0",
        "body-parser": "^2.2.2",
        "constate": "^3.3.3",
        "date-fns": "^4.1.0",
        "dotenv": "^17.4.1",
        "express": "^5.1.0",
        "express-session": "^1.19.0",
        "express-static-gzip": "^3.0.0",
        "http-proxy-middleware": "^3.0.5",
        "https-proxy-agent": "^7.0.6",
        "node-fetch": "3.3.2",
        "prom-client": "^15.1.3",
        "quill": "^2.0.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-pdf": "10.4.1",
        "react-router-dom": "7.14.0",
        "react-select": "^5.10.2",
        "styled-components": "^6.3.11",
        "use-debounce": "^10.1.1",
        "uuid": "^13.0.0",
        "winston": "^3.18.3"
    },
    "devDependencies": {
        "@axe-core/react": "4.11.1",
        "@eslint/js": "^9.39.4",
        "@types/express": "^5.0.5",
        "@types/express-session": "1.18.2",
        "@types/node": "^24.12.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/styled-components": "^5.1.34",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "6.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "postcss": "^8.5.9",
        "prettier": "^3.8.1",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.1",
        "vite": "^8.0.7",
        "vitest": "^4.1.3"
    }
}
